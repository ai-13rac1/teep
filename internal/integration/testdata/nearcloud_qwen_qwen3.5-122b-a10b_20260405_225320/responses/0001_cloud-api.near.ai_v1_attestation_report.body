XDTM1MTAxNDA0MTIyM1owKTEPMA0GA1UECgwGZHN0YWNrMRYw\nFAYDVQQDDA1kc3RhY2sgS01TIENBMFkwEwYHKoZIzj0CAQYIKoZIzj0DAQcDQgAE\nIo+ABZChBELLqdDmrbL6nxle6p514j3TWZDVK1ndokFaY2dMOK3r3k/9TUsmW/gY\nmFkzggyAU87jzim1+w+8vKNGMEQwDwYDVR0PAQH/BAUDAweGADAdBgNVHQ4EFgQU\nPSTxEnC0eBDGc3vsKYCnz3UaKzowEgYDVR0TAQH/BAgwBgEB/wIBATAKBggqhkjO\nPQQDAgNHADBEAiAajnZ9dcqsggH6QugOxyXM0lX7LpBtTymEIqi45d5mpwIgQa7K\niYvCXVIc36PWLub/wWbWoaCKgrFF5H3isr6Sv/Q=\n-----END CERTIFICATE-----\n","app_id":"f550fdfb4eb8ad787c1bcd423f091cbb4a4431ae","app_name":"dstack-0.5.4","compose_hash":"11369675e793061bbe1c4176cec902df45cea455922f86ee234d8332e32cdf93","device_id":"bf39c3a941240abbf138624951579673d7705144fed91ec3c3a57040e62794f2","instance_id":"3ace02696a267c13689b101e87855ca0a84255af","key_provider_info":"{\"name\":\"kms\",\"id\":\"3059301306072a8648ce3d020106082a8648ce3d03010703420004228f800590a10442cba9d0e6adb2fa9f195eea9e75e23dd35990d52b59dda2415a63674c38adebde4ffd4d4b265bf818985933820c8053cee3ce29b5fb0fbcbc\"}","mr_aggregated":"7fb0f6531a49e5ac423f69c64629abb29c8cf0d54cbfc1488bbe19a3558996a8","os_image_hash":"da9a3d5cc196a1a76d953fb27069be428ddf60a1ce10b0534c3cf968d3053fde","tcb_info":{"app_compose":"{\n    \"manifest_version\": 2,\n    \"name\": \"dstack-0.5.4\",\n    \"runner\": \"docker-compose\",\n    \"docker_compose_file\": \"# Docker Compose configuration for Cloud API in a VPC environment\\n# This setup includes the dstack-service for VPC management and an init container\\n# to prepare necessary configuration files before starting the Cloud API service.\\n\\nservices:\\n  # Datadog Service Definition\\n  datadog-agent:\\n    image: datadog/agent@sha256:5556fb80b952832719a76b016f905616c76ee0989a239c4680c6220148e865d6\\n    container_name: datadog-agent\\n    environment:\\n      - DD_API_KEY=${DD_API_KEY}\\n      - DD_SITE=us3.datadoghq.com\\n      - DD_ENV=prod\\n      - DD_LOGS_ENABLED=true\\n      - DD_LOGS_CONFIG_CONTAINER_COLLECT_ALL=true\\n      - DD_CONTAINER_EXCLUDE_LOGS=name:datadog-agent\\n      - DD_PROCESS_AGENT_ENABLED=true\\n      - DD_DOGSTATSD_NON_LOCAL_TRAFFIC=true\\n      - DD_HOSTNAME=$DD_HOSTNAME\\n      - DD_OTLP_CONFIG_RECEIVER_PROTOCOLS_GRPC_ENDPOINT=0.0.0.0:4317\\n    volumes:\\n      - /var/run/docker.sock:/var/run/docker.sock:ro\\n      - /proc/:/host/proc/:ro\\n      - /sys/fs/cgroup/:/host/sys/fs/cgroup:ro\\n      - /var/lib/docker/containers:/var/lib/docker/containers:ro\\n      - /run/log/journal:/run/log/journal:ro\\n      - /run/systemd/:/host/run/systemd/:ro\\n    configs:\\n      - source: journald_config_file\\n        target: /etc/datadog-agent/conf.d/journald.d/conf.yaml\\n        mode: 0755\\n    restart: unless-stopped\\n    logging: \\n        driver: \\\"json-file\\\"\\n        options:\\n          max-size: \\\"100m\\\"\\n          max-file: \\\"10\\\"\\n          labels: \\\"com.datadoghq.ad.logs\\\"\\n\\n\\n  # VPC Services Definition\\n  dstack-vpc-client:\\n    image: nearaidev/dstack-vpc-client@sha256:6f442f6cc1fcc10e925059df395533fedff8e5b0816c477cce78321d4a1f92d7\\n    container_name: dstack-vpc-client\\n    restart: on-failure\\n    cap_add:\\n      - NET_ADMIN\\n      - SYS_MODULE\\n    devices:\\n      - /dev/net/tun:/dev/net/tun\\n    network_mode: host\\n    volumes:\\n      - vpc_shared:/shared\\n      - vpc_node_data:/var/lib/tailscale\\n      - /var/run:/var/run\\n      - /dstack:/dstack\\n    environment:\\n      - NODE_NAME=cloud-api-prod\\n      - TUN_DEV_NAME=tailscale1\\n      - VPC_SERVER_APP_ID=e78c12915ad57900317b97bd16f59ae13f86f148\\n      - DSTACK_MESH_URL=http://localhost:9090\\n    healthcheck:\\n      test: [\\\"CMD\\\", \\\"tailscale\\\", \\\"status\\\"]\\n\\n  dstack-service-mesh:\\n    image: nearaidev/dstack-vpc@sha256:03bd4b222d07059af91fc3d2aa851026cecbecf719ba7423616058272db57b2c\\n    container_name: dstack-service-mesh\\n    restart: on-failure\\n    ports:\\n      - \\\"443:443\\\"\\n      - \\\"9090:80\\\"\\n    volumes:\\n      - /var/run/dstack.sock:/var/run/dstack.sock\\n      - /var/run/docker.sock:/var/run/docker.sock\\n      - vpc_shared:/vpc/0:ro\\n    privileged: true\\n    environment:\\n      - DSTACK_GATEWAY_DOMAIN=cvm1.near.ai\\n      - DSTACK_MESH_BACKEND=127.0.0.1:8000\\n      - DSTACK_CONTAINER_IMAGE_ID=nearaidev/dstack-vpc@sha256:03bd4b222d07059af91fc3d2aa851026cecbecf719ba7423616058272db57b2c\\n      - RUST_LOG=error\\n    command: /scripts/mesh-serve.sh\\n\\n\\n  # Init container to prepare configuration\\n  api-init:\\n    image: alpine@sha256:4b7ce07002c69e8f3d704a9c5d6fd3053be500b7f1c69fc0d80990c2ad8dd412\\n    container_name: api-init\\n    restart: \\\"no\\\"\\n    volumes:\\n      - api_config:/config\\n      - vpc_shared:/shared\\n    configs:\\n      - source: api_init_script\\n        target: /init.sh\\n        mode: 0755\\n    command: [\\\"/init.sh\\\"]\\n\\n  # Cloud API service\\n  cloud-api:\\n    container_name: cloud-api\\n    image: nearaidev/cloud-api@sha256:e15c0cf6a7ef195f01345a955b9c0a171549e0e055f49d23c6462da2b0ec0a2b\\n    restart: unless-stopped\\n    volumes:\\n      - /var/run/dstack.sock:/var/run/dstack.sock\\n      - api_config:/config:ro\\n      - ingress_certs:/ingress-certs:ro\\n    environment:\\n      - POSTGRES_PRIMARY_APP_ID=c5f76292a3df94d50056b08e57fc30fe1081ad40\\n      - VPC_SERVER_APP_ID=e78c12915ad57900317b97bd16f59ae13f86f148\\n      - SERVER_HOST=0.0.0.0\\n      - SERVER_PORT=3000\\n      - DATABASE_MAX_CONNECTIONS=32\\n      - DATABASE_REFRESH_INTERVAL=300\\n      - MODEL_DISCOVERY_SERVER_URL=${MODEL_DISCOVERY_SERVER_URL}\\n      - MODEL_DISCOVERY_API_KEY=${MODEL_DISCOVERY_API_KEY}\\n      - MODEL_DISCOVERY_REFRESH_INTERVAL=60\\n      - MODEL_DISCOVERY_TIMEOUT=5\\n      - LOG_LEVEL=info\\n      - LOG_FORMAT=json\\n      - RUST_LOG=info\\n      - RUST_BACKTRACE=1\\n      - LOG_MODULE_API=info\\n      - LOG_MODULE_SERVICES=info\\n      - DSTACK_CLIENT_URL=http://localhost:8000\\n      - AUTH_MOCK=false\\n      - GITHUB_CLIENT_ID=${GITHUB_CLIENT_ID}\\n      - GITHUB_CLIENT_SECRET=${GITHUB_CLIENT_SECRET}\\n      - GITHUB_REDIRECT_URL=https://cloud-api.near.ai/v1/auth/callback\\n      - GOOGLE_CLIENT_ID=${GOOGLE_CLIENT_ID}\\n      - GOOGLE_CLIENT_SECRET=${GOOGLE_CLIENT_SECRET}\\n      - GOOGLE_REDIRECT_URL=https://cloud-api.near.ai/v1/auth/callback\\n      - AUTH_ADMIN_DOMAINS=${AUTH_ADMIN_DOMAINS}\\n      - DATABASE_NAME=${DATABASE_NAME}\\n      - DATABASE_USERNAME=${DATABASE_USERNAME}\\n      - DATABASE_TLS_ENABLED=true\\n      - DATABASE_PASSWORD_FILE=/config/postgres-password\\n      - AUTH_ENCODING_KEY=${AUTH_ENCODING_KEY}\\n      - VPC_HOSTNAME_FILE=/config/vpc_hostname\\n      - VPC_SHARED_SECRET_FILE=/config/keyfile\\n      - S3_ENCRYPTION_KEY_FILE=/config/s3-encryption-key\\n      - AWS_S3_BUCKET=${AWS_S3_BUCKET}\\n      - AWS_S3_REGION=${AWS_S3_REGION}\\n      - AWS_REGION=${AWS_S3_REGION}\\n      - AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}\\n      - AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}\\n      - BRAVE_SEARCH_PRO_API_KEY=${BRAVE_SEARCH_PRO_API_KEY}\\n      - GATEWAY_SUBDOMAIN=cvm1.near.ai\\n      - CORS_ALLOWED_ORIGINS=${CORS_ALLOWED_ORIGINS}\\n      - ENVIRONMENT=prod\\n      - TELEMETRY_SERVICE_NAME=cloud-api\\n      - TELEMETRY_OTLP_ENDPOINT=http://datadog-agent:4317\\n      - GEMINI_API_KEY=${GEMINI_API_KEY}\\n      - OPENAI_API_KEY=${OPENAI_API_KEY}\\n      - ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}\\n      - EXTERNAL_PROVIDER_TIMEOUT=${EXTERNAL_PROVIDER_TIMEOUT}\\n      - TLS_CERT_PATH=/ingress-certs/cloud-api.near.ai/fullchain.pem\\n    dns:\\n      - 100.100.100.100\\n      - 1.1.1.1\\n    dns_search:\\n      - dstack.internal\\n    ports:\\n      - \\\"3000:3000\\\"\\n    depends_on:\\n      api-init:\\n        condition: service_completed_successfully\\n      ingress:\\n        condition: service_healthy\\n    healthcheck:\\n      test:\\n        [\\\"CMD-SHELL\\\", \\\"curl -f http://127.0.0.1:3000/v1/model/list || exit 1\\\"]\\n      interval: 30s\\n      timeout: 3s\\n      retries: 10\\n      start_period: 40s\\n    labels:\\n      com.datadoghq.ad.logs: '[{\\\"source\\\": \\\"cloud-api\\\", \\\"service\\\": \\\"cloud-api\\\"}]'\\n\\n  # Ingress sidecar: nginx reverse proxy (TLS optional)\\n  ingress:\\n    container_name: ingress\\n    image: nearaidev/cvm-ingress@sha256:c83415077f60647aa4de3da326aca6c3935bb065d0de2dac728f81fc6bae55d9\\n    restart: unless-stopped\\n    environment:\\n      - DOMAIN=cloud-api.near.ai\\n      - BACKEND_HOST=cloud-api\\n      - BACKEND_PORT=3000\\n      - TLS_ENABLED=true\\n      - CERTBOT_EMAIL=${CERTBOT_EMAIL}\\n      - CLOUDFLARE_API_TOKEN=${CLOUDFLARE_API_TOKEN}\\n      - S3_BUCKET=${INGRESS_S3_BUCKET}\\n      - S3_PREFIX=cloud-api-prod\\n      - AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}\\n      - AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}\\n      - AWS_DEFAULT_REGION=${AWS_DEFAULT_REGION}\\n      - STAGING=false\\n    volumes:\\n      - /var/run/dstack.sock:/var/run/dstack.sock\\n      - ingress_certs:/certs\\n    ports:\\n      - \\\"8443:8443\\\"\\n    healthcheck:\\n      test: [\\\"CMD-SHELL\\\", \\\"test -f /certs/cloud-api.near.ai/fullchain.pem\\\"]\\n      interval: 5s\\n      timeout: 3s\\n      retries: 60\\n      start_period: 10s\\n    labels:\\n      com.datadoghq.ad.logs: '[{\\\"source\\\": \\\"nginx\\\", \\\"service\\\": \\\"ingress\\\"}]'\\n\\nvolumes:\\n  api_config:\\n  ingress_certs:\\n  # VPC Volumes\\n  vpc_shared:\\n  vpc_node_data:\\n\\nconfigs:\\n  # Journald conf file content\\n  journald_config_file:\\n    content: |\\n      logs:\\n        - type: journald\\n          container_mode: true\\n          # TODO: Add filters to reduce log volume\\n\\n  api_init_script:\\n    content: |\\n      #!/bin/sh\\n      set -e\\n\\n      echo \\\"Cloud API initialization starting...\\\"\\n\\n      # Wait for file to exist in /shared\\n      echo \\\"Waiting for /shared/shared_key to exist...\\\"\\n      while [ ! -f /shared/shared_key ]; do\\n        sleep 2\\n      done\\n      echo \\\"/shared/shared_key exists\\\"\\n\\n      echo \\\"Copying shared key to /config/keyfile...\\\"\\n      cp /shared/shared_key /config/keyfile\\n      chmod 644 /config/keyfile\\n\\n      # Derive PostgreSQL password from keyfile (same algorithm as Patroni)\\n      POSTGRES_PASSWORD=$$(head -c 32 /config/keyfile | base64 | tr -d \\\"\\\\n\\\")\\n      echo \\\"$$POSTGRES_PASSWORD\\\" > /config/postgres-password\\n      chmod 644 /config/postgres-password\\n\\n      echo \\\"Copying actual hostname to /config/vpc_hostname...\\\"\\n      cp /shared/actual_hostname /config/vpc_hostname\\n      chmod 644 /config/vpc_hostname\\n\\n      # Derive S3 encryption key (32 bytes) from keyfile\\n      # Read 32 raw bytes, which are then converted to a 64-character hex string.\\n      S3_ENCRYPTION_KEY=$(head -c 32 /config/keyfile | xxd -p | tr -d '\\\\n')\\n      echo \\\"$$S3_ENCRYPTION_KEY\\\" > /config/s3-encryption-key\\n      chmod 644 /config/s3-encryption-key\\n\\n      echo \\\"Initialization complete\\\"\\n\",\n    \"kms_enabled\": true,\n    \"gateway_enabled\": true,\n    \"local_key_provider_enabled\": false,\n    \"key_provider_id\": \"\",\n    \"public_logs\": false,\n    \"public_sysinfo\": true,\n    \"allowed_envs\": [\n        \"DATABASE_NAME\",\n        \"DATABASE_USERNAME\",\n        \"MODEL_DISCOVERY_SERVER_URL\",\n        \"MODEL_DISCOVERY_API_KEY\",\n        \"AUTH_ENCODING_KEY\",\n        \"GITHUB_CLIENT_ID\",\n        \"GITHUB_CLIENT_SECRET\",\n        \"GOOGLE_CLIENT_ID\",\n        \"GOOGLE_CLIENT_SECRET\",\n        \"AUTH_ADMIN_DOMAINS\",\n        \"AWS_S3_BUCKET\",\n        \"AWS_S3_REGION\",\n        \"AWS_REGION\",\n        \"AWS_ACCESS_KEY_ID\",\n        \"AWS_SECRET_ACCESS_KEY\",\n        \"BRAVE_SEARCH_PRO_API_KEY\",\n        \"CORS_ALLOWED_ORIGINS\",\n        \"NEAR_EXPECTED_RECIPIENT\",\n        \"GEMINI_API_KEY\",\n        \"OPENAI_API_KEY\",\n        \"ANTHROPIC_API_KEY\",\n        \"EXTERNAL_PROVIDER_TIMEOUT\",\n        \"CERTBOT_EMAIL\",\n        \"CLOUDFLARE_API_TOKEN\",\n        \"INGRESS_S3_BUCKET\",\n        \"AWS_DEFAULT_REGION\",\n        \"DD_API_KEY\",\n        \"HUGGING_FACE_HUB_TOKEN\",\n        \"PROXY_TOKEN\",\n        \"ENV\",\n        \"HOST_IP\",\n        \"DD_HOSTNAME\"\n    ],\n    \"no_instance_id\": false,\n    \"secure_time\": false\n}","compose_hash":"11369675e793061bbe1c4176cec902df45cea455922f86ee234d8332e32cdf93","device_id":"bf39c3a941240abbf138624951579673d7705144fed91ec3c3a57040e62794f2","event_log":[{"digest":"2e070cda358b5aa00f27cca25c47381bb564f4be3a84d059805a73cbbde764ed8341f7e09915b5e7b370f9c08a743fbd","event":"","event_payload":"095464785461626c65000100000000000000af96bb93f2b9b84e9462e0ba745642360090800000000000","event_type":2147483659,"imr":0},{"digest":"344bc51c980ba621aaa00da3ed7436f7d6e549197dfe699515dfa2c6583d95e6412af21c097d473155875ffd561d6790","event":"","event_payload":"2946762858585858585858582d585858582d585858582d585858582d58585858585858585858585829000000c0ff000000000040080000000000","event_type":2147483658,"imr":0},{"digest":"9dc3a1f80bcec915391dcda5ffbb15e7419f77eab462bbf72b42166fb70d50325e37b36f93537a863769bcf9bedae6fb","event":"","event_payload":"61dfe48bca93d211aa0d00e098032b8c0a00000000000000000000000000000053006500630075007200650042006f006f007400","event_type":2147483649,"imr":0},{"digest":"6f2e3cbc14f9def86980f5f66fd85e99d63e69a73014ed8a5633ce56eca5b64b692108c56110e22acadcef58c3250f1b","event":"","event_payload":"61dfe48bca93d211aa0d00e098032b8c0200000000000000000000000000000050004b00","event_type":2147483649,"imr":0},{"digest":"d607c0efb41c0d757d69bca0615c3a9ac0b1db06c557d992e906c6b7dee40e0e031640c7bfd7bcd35844ef9edeadc6f9","event":"","event_payload":"61dfe48bca93d211aa0d00e098032b8c030000000000000000000000000000004b0045004b00","event_type":2147483649,"imr":0},{"digest":"08a74f8963b337acb6c93682f934496373679dd26af1089cb4eaf0c30cf260a12e814856385ab8843e56a9acea19e127","event":"","event_payload":"cbb219d73a3d9645a3bcdad00e67656f0200000000000000000000000000000064006200","event_type":2147483649,