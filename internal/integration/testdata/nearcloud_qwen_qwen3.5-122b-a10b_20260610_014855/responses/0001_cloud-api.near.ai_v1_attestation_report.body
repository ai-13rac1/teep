256:5556fb80b952832719a76b016f905616c76ee0989a239c4680c6220148e865d6\\n    container_name: datadog-agent\\n    environment:\\n      - DD_API_KEY=${DD_API_KEY}\\n      - DD_SITE=us3.datadoghq.com\\n      - DD_ENV=prod\\n      - DD_LOGS_ENABLED=true\\n      - DD_LOGS_CONFIG_CONTAINER_COLLECT_ALL=true\\n      - DD_CONTAINER_EXCLUDE_LOGS=name:datadog-agent\\n      - DD_PROCESS_AGENT_ENABLED=true\\n      - DD_DOGSTATSD_NON_LOCAL_TRAFFIC=true\\n      - DD_HOSTNAME=$DD_HOSTNAME\\n      - DD_OTLP_CONFIG_RECEIVER_PROTOCOLS_GRPC_ENDPOINT=0.0.0.0:4317\\n    volumes:\\n      - /var/run/docker.sock:/var/run/docker.sock:ro\\n      - /proc/:/host/proc/:ro\\n      - /sys/fs/cgroup/:/host/sys/fs/cgroup:ro\\n      - /var/lib/docker/containers:/var/lib/docker/containers:ro\\n      - /run/log/journal:/run/log/journal:ro\\n      - /run/systemd/:/host/run/systemd/:ro\\n    configs:\\n      - source: journald_config_file\\n        target: /etc/datadog-agent/conf.d/journald.d/conf.yaml\\n        mode: 0755\\n    restart: unless-stopped\\n    logging: \\n        driver: \\\"json-file\\\"\\n        options:\\n          max-size: \\\"100m\\\"\\n          max-file: \\\"10\\\"\\n          labels: \\\"com.datadoghq.ad.logs\\\"\\n\\n\\n  certbot:\\n    image: certbot/dns-cloudflare@sha256:742dbd2e61c8709b930712c38958386c3cb3928e09eeb1f1e490600c127e2edb\\n    restart: unless-stopped\\n    entrypoint: \\\"/bin/sh -c 'trap exit TERM; while :; do certbot renew; sleep 12h & wait $${!}; done;'\\\"\\n    volumes:\\n      - certs:/etc/letsencrypt\\n    configs:\\n      - source: cloudflare_credentials\\n        target: /etc/cloudflare/credentials.ini\\n        mode: 0600\\n    depends_on:\\n      certbot-init:\\n        condition: service_completed_successfully\\n\\n  certbot-init:\\n    image: certbot/dns-cloudflare@sha256:742dbd2e61c8709b930712c38958386c3cb3928e09eeb1f1e490600c127e2edb\\n    volumes:\\n      - certs:/etc/letsencrypt\\n    restart: on-failure\\n    configs:\\n      - source: cloudflare_credentials\\n        target: /etc/cloudflare/credentials.ini\\n        mode: 0600\\n    command: >\\n      certonly\\n      --dns-cloudflare\\n      --dns-cloudflare-credentials /etc/cloudflare/credentials.ini\\n      --dns-cloudflare-propagation-seconds 30\\n      --email ${CERTBOT_EMAIL}\\n      --agree-tos --no-eff-email --non-interactive\\n      --key-type ecdsa --elliptic-curve secp256r1\\n      --cert-name completions.near.ai\\n      -d \\\"*.completions.near.ai\\\"\\n      -d \\\"completions.near.ai\\\"\\n      -d \\\"$HOSTNAME.hosts.near.ai\\\"\\n\\n  compose-manager:\\n    image: ${COMPOSE_MANAGER_IMAGE:-nearaidev/compose-manager@sha256:44aa2344d68609700074a8076ed177bb1989c7f5fd1e175a13084d512be475e9}\\n    container_name: compose-manager\\n    restart: unless-stopped\\n    ports:\\n      - \\\"8080:8080\\\"\\n    # pid:host + CAP_SYS_ADMIN + CAP_SYS_PTRACE let compose-manager run\\n    # `nsenter -t 1 -m -u -i -n -p -- ...` into PID 1's namespaces.\\n    #   - SYS_PTRACE: needed to open /proc/1/ns/* (ptrace_may_access gates\\n    #     this — PID 1 has `dumpable=0` because it was launched with a full\\n    #     cap set, so even root in the same user-ns needs SYS_PTRACE).\\n    #   - SYS_ADMIN: needed for the setns() that follows the open.\\n    # Without BOTH, every nsenter call fails with \\\"cannot open /proc/1/ns/*:\\n    # Permission denied\\\" — affecting `/dstack-agent/:action` (pre-existing)\\n    # and `/admin/kernel/algif-blacklist` (PR #14 / CVE-2026-31431).\\n    #\\n    # NOTE on AppArmor: on a host with AppArmor enabled, docker-default also\\n    # blocks this regardless of caps; the workable combo there is\\n    # `cap_add: [SYS_ADMIN, SYS_PTRACE]` PLUS `security_opt:\\n    # apparmor=unconfined`. dstack-OS does NOT ship AppArmor (verified\\n    # 2026-05-19 — no apparmor binaries/profiles in the rootfs, no AppArmor\\n    # strings in bzImage), so we omit the `security_opt` line. If a future\\n    # dstack-OS image enables AppArmor, this template must add it.\\n    pid: host\\n    cap_add:\\n      - SYS_ADMIN\\n      - SYS_PTRACE\\n    volumes:\\n      - /var/run/docker.sock:/var/run/docker.sock\\n      - /var/run/dstack.sock:/var/run/dstack.sock\\n      - /dstack/.host-shared/.decrypted-env:/app/.env:ro\\n      - work:/app/work\\n    environment:\\n      - GITHUB_REPO=https://github.com/nearai/cvm-compose-files\\n      - BEARER_TOKEN=${BEARER_TOKEN}\\n      - WORK_DIR=/app/work\\n      - MIN_TAG_AGE_HOURS=2\\n      - ENV_FILES=/app/.env\\n      # Slack ops notifications (nearai/infra#141). INSTANCE_LABEL identifies\\n      # this host in the message (\\\"Deployed on gpuXX\\\"); SLACK_WEBHOOK_URL is a\\n      # secret sourced from the CVM decrypted env (empty = notifications off).\\n      - INSTANCE_LABEL=gpu30\\n      - SLACK_WEBHOOK_URL=${SLACK_WEBHOOK_URL:-}\\n    labels:\\n      com.datadoghq.ad.logs: '[{\\\"source\\\": \\\"compose-manager\\\", \\\"service\\\": \\\"compose-manager\\\"}]'\\n\\n  compose-manager-launcher:\\n    image: nearaidev/compose-manager-launcher@sha256:171c1cffea23625628fc11038a590173745d83e3570d855e53ab5a91279f95bf\\n    container_name: compose-manager-launcher\\n    restart: unless-stopped\\n    # Host network so the launcher's health check (LAUNCHER_HEALTH_URL below,\\n    # http://127.0.0.1:8080/version) can reach compose-manager, which publishes\\n    # 8080 on the guest host via `ports: 8080:8080`. On the default bridge,\\n    # 127.0.0.1 is the launcher's own loopback and the check can never pass —\\n    # every swap/rollback would be wrongly declared failed.\\n    network_mode: host\\n    volumes:\\n      - /var/run/docker.sock:/var/run/docker.sock\\n      # Mounted read-only so the launcher can pass it as --env-file to docker compose,\\n      # allowing BEARER_TOKEN and other secrets to be substituted in the bundled\\n      # compose file without the launcher holding them in its own environment.\\n      - /dstack/.host-shared/.decrypted-env:/dstack-env:ro\\n      - work:/app/work\\n    environment:\\n      - COMPOSE_MANAGER_IMAGE_REPO=nearaidev/compose-manager\\n      - LAUNCHER_CHANNEL=${LAUNCHER_CHANNEL:-latest}\\n      - LAUNCHER_COMPOSE_PROJECT=dstack\\n      - LAUNCHER_ENV_FILE=/app/work/.env.launcher\\n      - LAUNCHER_BASE_ENV_FILE=/dstack-env\\n      - LAUNCHER_HEALTH_URL=http://127.0.0.1:8080/version\\n      # compose-manager does TLS/cert + S3 + git work on startup, so a container\\n      # recreate can take >60s to answer /version. 60s caused a genuine swap (and\\n      # its rollback) to be declared failed mid-startup -> false 30-min backoff.\\n      - LAUNCHER_HEALTH_TIMEOUT=180\\n      - LAUNCHER_COSIGN_IDENTITY_REGEXP=https://github.com/nearai/compose-manager/.github/workflows/.*\\n      - DOCKER_REGISTRY_USER=${DOCKER_REGISTRY_USER:-}\\n      - DOCKER_REGISTRY_TOKEN=${DOCKER_REGISTRY_TOKEN:-}\\n      - LAUNCHER_STATE_FILE=/app/work/launcher-state.json\\n    depends_on:\\n      - compose-manager\\n    labels:\\n      com.datadoghq.ad.logs: '[{\\\"source\\\": \\\"compose-manager-launcher\\\", \\\"service\\\": \\\"compose-manager-launcher\\\"}]'\\n\\nvolumes:\\n  work:\\n  # This volume can be re-used by other containers that need access to the TLS certificates.\\n  certs:\\n    name: certs\\n\\nconfigs:\\n  cloudflare_credentials:\\n    content: |\\n      dns_cloudflare_api_token = ${CLOUDFLARE_API_TOKEN}\\n\\n  # Journald conf file content\\n  journald_config_file:\\n    content: |\\n      logs:\\n        - type: journald\\n          container_mode: true\\n          # TODO: Add filters to reduce log volume\\n\",\n    \"kms_enabled\": true,\n    \"gateway_enabled\": true,\n    \"local_key_provider_enabled\": false,\n    \"key_provider_id\": \"\",\n    \"public_logs\": false,\n    \"public_sysinfo\": true,\n    \"allowed_envs\": [\n        \"BEARER_TOKEN\",\n        \"SLACK_WEBHOOK_URL\",\n        \"AWS_REGION\",\n        \"AWS_ACCESS_KEY_ID\",\n        \"AWS_SECRET_ACCESS_KEY\",\n        \"AWS_S3_BUCKET\",\n        \"CERTBOT_EMAIL\",\n        \"CLOUDFLARE_API_TOKEN\",\n        \"DOCKER_REGISTRY_USER\",\n        \"DOCKER_REGISTRY_TOKEN\",\n        \"LAUNCHER_CHANNEL\",\n        \"DD_API_KEY\",\n        \"HUGGING_FACE_HUB_TOKEN\",\n        \"PROXY_TOKEN\",\n        \"ENV\",\n        \"HOST_IP\",\n        \"DD_HOSTNAME\",\n        \"HOSTNAME\"\n    ],\n    \"no_instance_id\": false,\n    \"secure_time\": false,\n    \"pre_launch_script\": \"#!/bin/bash\\nexport ENCRYPTION_KEY=$(cat /dstack/.host-shared/.appkeys.json | jq -r .k256_key)\\n\"\n}","compose_hash":"4676ec04ecaff0303142bd3b76205ffc7bc218adaa91b92c10863d4fa6463a3f","device_id":"aa781567445c6a3c11d26b41bd395aef2eb3cb343d9bb0e48ce34649c3d19e85","event_log":[{"digest":"60a36090e82db2aa82a7abb76029b9ace69e9f0811b7029ff25a26a2e8b91c182696df92674ab571c42093383e1fcc71","event":"","event_payload":"095464785461626c65000100000000000000af96bb93f2b9b84e9462e0ba745642360090800000000000","event_type":2147483659,"imr":0},{"digest":"344bc51c980ba621aaa00da3ed7436f7d6e549197dfe699515dfa2c6583d95e6412af21c097d473155875ffd561d6790","event":"","event_payload":"2946762858585858585858582d585858582d585858582d585858582d58585858585858585858585829000000c0ff000000000040080000000000","event_type":2147483658,"imr":0},{"digest":"9dc3a1f80bcec915391dcda5ffbb15e7419f77eab462bbf72b42166fb70d50325e37b36f93537a863769bcf9bedae6fb","event":"","event_payload":"61dfe48bca93d211aa0d00e098032b8c0a00000000000000000000000000000053006500630075007200650042006f006f007400","event_type":2147483649,"imr":0},{"digest":"6f2e3cbc14f9def86980f5f66fd85e99d63e69a73014ed8a5633ce56eca5b64b692108c56110e22acadcef58c3250f1b","event":"","event_payload":"61dfe48bca93d211aa0d00e098032b8c0200000000000000000000000000000050004b00","event_type":2147483649,"imr":0},{"digest":"d607c0efb41c0d757d69bca0615c3a9ac0b1db06c557d992e906c6b7dee40e0e031640c7bfd7bcd35844ef9edeadc6f9","event":"","event_payload":"61dfe48bca93d211aa0d00e098032b8c030000000000000000000000000000004b0045004b00","event_ty