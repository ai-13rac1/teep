n      - DD_API_KEY=${DD_API_KEY}\\n      - DD_SITE=us3.datadoghq.com\\n      - DD_ENV=prod\\n      - DD_LOGS_ENABLED=true\\n      - DD_LOGS_CONFIG_CONTAINER_COLLECT_ALL=true\\n      - DD_CONTAINER_EXCLUDE_LOGS=name:datadog-agent\\n      - DD_PROCESS_AGENT_ENABLED=true\\n      - DD_DOGSTATSD_NON_LOCAL_TRAFFIC=true\\n      - DD_HOSTNAME=$DD_HOSTNAME\\n      - DD_OTLP_CONFIG_RECEIVER_PROTOCOLS_GRPC_ENDPOINT=0.0.0.0:4317\\n    volumes:\\n      - /var/run/docker.sock:/var/run/docker.sock:ro\\n      - /proc/:/host/proc/:ro\\n      - /sys/fs/cgroup/:/host/sys/fs/cgroup:ro\\n      - /var/lib/docker/containers:/var/lib/docker/containers:ro\\n      - /run/log/journal:/run/log/journal:ro\\n      - /run/systemd/:/host/run/systemd/:ro\\n    configs:\\n      - source: journald_config_file\\n        target: /etc/datadog-agent/conf.d/journald.d/conf.yaml\\n        mode: 0755\\n    restart: unless-stopped\\n    logging: \\n        driver: \\\"json-file\\\"\\n        options:\\n          max-size: \\\"100m\\\"\\n          max-file: \\\"10\\\"\\n          labels: \\\"com.datadoghq.ad.logs\\\"\\n\\n\\n  certbot:\\n    image: certbot/dns-cloudflare@sha256:742dbd2e61c8709b930712c38958386c3cb3928e09eeb1f1e490600c127e2edb\\n    restart: unless-stopped\\n    entrypoint: \\\"/bin/sh -c 'trap exit TERM; while :; do certbot renew; sleep 12h & wait $${!}; done;'\\\"\\n    volumes:\\n      - certs:/etc/letsencrypt\\n    configs:\\n      - source: cloudflare_credentials\\n        target: /etc/cloudflare/credentials.ini\\n        mode: 0600\\n    depends_on:\\n      certbot-init:\\n        condition: service_completed_successfully\\n\\n  certbot-init:\\n    image: certbot/dns-cloudflare@sha256:742dbd2e61c8709b930712c38958386c3cb3928e09eeb1f1e490600c127e2edb\\n    volumes:\\n      - certs:/etc/letsencrypt\\n    restart: on-failure\\n    configs:\\n      - source: cloudflare_credentials\\n        target: /etc/cloudflare/credentials.ini\\n        mode: 0600\\n    command: >\\n      certonly\\n      --dns-cloudflare\\n      --dns-cloudflare-credentials /etc/cloudflare/credentials.ini\\n      --dns-cloudflare-propagation-seconds 30\\n      --email ${CERTBOT_EMAIL}\\n      --agree-tos --no-eff-email --non-interactive\\n      --key-type ecdsa --elliptic-curve secp256r1\\n      --cert-name completions.near.ai\\n      -d \\\"*.completions.near.ai\\\"\\n      -d \\\"completions.near.ai\\\"\\n      -d \\\"$HOSTNAME.hosts.near.ai\\\"\\n\\n  compose-manager:\\n    image: nearaidev/compose-manager@sha256:a3c6e223ae5643689e6f0ae78461c2cb2d1b52d5b4ea306dc354b9ac7096d6e2\\n    container_name: compose-manager\\n    restart: unless-stopped\\n    ports:\\n      - \\\"8080:8080\\\"\\n    volumes:\\n      - /var/run/docker.sock:/var/run/docker.sock\\n      - /var/run/dstack.sock:/var/run/dstack.sock\\n      - /dstack/.host-shared/.decrypted-env:/app/.env:ro\\n      - work:/app/work\\n    environment:\\n      - GITHUB_REPO=https://github.com/nearai/cvm-compose-files\\n      - BEARER_TOKEN=${BEARER_TOKEN}\\n      - WORK_DIR=/app/work\\n      - MIN_TAG_AGE_HOURS=2\\n      - ENV_FILES=/app/.env\\n    labels:\\n      com.datadoghq.ad.logs: '[{\\\"source\\\": \\\"compose-manager\\\", \\\"service\\\": \\\"compose-manager\\\"}]'\\n\\nvolumes:\\n  work:\\n  # This volume can be re-used by other containers that need access to the TLS certificates.\\n  certs:\\n    name: certs\\n\\nconfigs:\\n  cloudflare_credentials:\\n    content: |\\n      dns_cloudflare_api_token = ${CLOUDFLARE_API_TOKEN}\\n\\n  # Journald conf file content\\n  journald_config_file:\\n    content: |\\n      logs:\\n        - type: journald\\n          container_mode: true\\n          # TODO: Add filters to reduce log volume\\n\",\n    \"kms_enabled\": true,\n    \"gateway_enabled\": true,\n    \"local_key_provider_enabled\": false,\n    \"key_provider_id\": \"\",\n    \"public_logs\": false,\n    \"public_sysinfo\": true,\n    \"allowed_envs\": [\n        \"BEARER_TOKEN\",\n        \"AWS_REGION\",\n        \"AWS_ACCESS_KEY_ID\",\n        \"AWS_SECRET_ACCESS_KEY\",\n        \"AWS_S3_BUCKET\",\n        \"CERTBOT_EMAIL\",\n        \"CLOUDFLARE_API_TOKEN\",\n        \"DD_API_KEY\",\n        \"HUGGING_FACE_HUB_TOKEN\",\n        \"PROXY_TOKEN\",\n        \"ENV\",\n        \"HOST_IP\",\n        \"DD_HOSTNAME\",\n        \"HOSTNAME\"\n    ],\n    \"no_instance_id\": false,\n    \"secure_time\": false,\n    \"pre_launch_script\": \"#!/bin/bash\\nexport ENCRYPTION_KEY=$(cat /dstack/.host-shared/.appkeys.json | jq -r .k256_key)\\n\"\n}","compose_hash":"242a62724303cc32f364da0fc92738706b0078e7587821b7ba3e75488223797b","device_id":"71b4c123bc28aa4dd49845bb2785848b1fcb4f1b87b688472e690f1e5687f2d3","event_log":[{"digest":"60a36090e82db2aa82a7abb76029b9ace69e9f0811b7029ff25a26a2e8b91c182696df92674ab571c42093383e1fcc71","event":"","event_payload":"095464785461626c65000100000000000000af96bb93f2b9b84e9462e0ba745642360090800000000000","event_type":2147483659,"imr":0},{"digest":"344bc51c980ba621aaa00da3ed7436f7d6e549197dfe699515dfa2c6583d95e6412af21c097d473155875ffd561d6790","event":"","event_payload":"2946762858585858585858582d585858582d585858582d585858582d58585858585858585858585829000000c0ff000000000040080000000000","event_type":2147483658,"imr":0},{"digest":"9dc3a1f80bcec915391dcda5ffbb15e7419f77eab462bbf72b42166fb70d50325e37b36f93537a863769bcf9bedae6fb","event":"","event_payload":"61dfe48bca93d211aa0d00e098032b8c0a00000000000000000000000000000053006500630075007200650042006f006f007400","event_type":2147483649,"imr":0},{"digest":"6f2e3cbc14f9def86980f5f66fd85e99d63e69a73014ed8a5633ce56eca5b64b692108c56110e22acadcef58c3250f1b","event":"","event_payload":"61dfe48bca93d211aa0d00e098032b8c0200000000000000000000000000000050004b00","event_type":2147483649,"imr":0},{"digest":"d607c0efb41c0d757d69bca0615c3a9ac0b1db06c557d992e906c6b7dee40e0e031640c7bfd7bcd35844ef9edeadc6f9","event":"","event_payload":"61dfe48bca93d211aa0d00e098032b8c030000000000000000000000000000004b0045004b00","event_type":2147483649,"imr"