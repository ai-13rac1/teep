nC1GAuEUT1vtOXq80cbA6VMaQWfOUvDHIsO2MxXJQ\n-----END CERTIFICATE-----\n","app_id":"2c0a0c96cb6dbd659bf1446e2f3fce58172ff91b","app_name":"dstack-nvidia-0.5.5","compose_hash":"242a62724303cc32f364da0fc92738706b0078e7587821b7ba3e75488223797b","device_id":"71b4c123bc28aa4dd49845bb2785848b1fcb4f1b87b688472e690f1e5687f2d3","instance_id":"53290d37def903fc362ac725695306748028e796","key_provider_info":"{\"name\":\"kms\",\"id\":\"3059301306072a8648ce3d020106082a8648ce3d03010703420004228f800590a10442cba9d0e6adb2fa9f195eea9e75e23dd35990d52b59dda2415a63674c38adebde4ffd4d4b265bf818985933820c8053cee3ce29b5fb0fbcbc\"}","mr_aggregated":"80f6492d854986684a77f830a79d9b291ade80df78549e61e0f2d13a135167aa","os_image_hash":"9b69bb1698bacbb6985409a2c272bcb892e09cdcea63d5399c6768b67d3ff677","tcb_info":{"app_compose":"{\n    \"manifest_version\": 2,\n    \"name\": \"dstack-nvidia-0.5.5\",\n    \"runner\": \"docker-compose\",\n    \"docker_compose_file\": \"services:\\n  # Datadog Service Definition\\n  datadog-agent:\\n    image: datadog/agent@sha256:5556fb80b952832719a76b016f905616c76ee0989a239c4680c6220148e865d6\\n    container_name: datadog-agent\\n    environment:\\n      - DD_API_KEY=${DD_API_KEY}\\n      - DD_SITE=us3.datadoghq.com\\n      - DD_ENV=prod\\n      - DD_LOGS_ENABLED=true\\n      - DD_LOGS_CONFIG_CONTAINER_COLLECT_ALL=true\\n      - DD_CONTAINER_EXCLUDE_LOGS=name:datadog-agent\\n      - DD_PROCESS_AGENT_ENABLED=true\\n      - DD_DOGSTATSD_NON_LOCAL_TRAFFIC=true\\n      - DD_HOSTNAME=$DD_HOSTNAME\\n      - DD_OTLP_CONFIG_RECEIVER_PROTOCOLS_GRPC_ENDPOINT=0.0.0.0:4317\\n    volumes:\\n      - /var/run/docker.sock:/var/run/docker.sock:ro\\n      - /proc/:/host/proc/:ro\\n      - /sys/fs/cgroup/:/host/sys/fs/cgroup:ro\\n      - /var/lib/docker/containers:/var/lib/docker/containers:ro\\n      - /run/log/journal:/run/log/journal:ro\\n      - /run/systemd/:/host/run/systemd/:ro\\n    configs:\\n      - source: journald_config_file\\n        target: /etc/datadog-agent/conf.d/journald.d/conf.yaml\\n        mode: 0755\\n    restart: unless-stopped\\n    logging: \\n        driver: \\\"json-file\\\"\\n        options:\\n          max-size: \\\"100m\\\"\\n          max-file: \\\"10\\\"\\n          labels: \\\"com.datadoghq.ad.logs\\\"\\n\\n\\n  certbot:\\n    image: certbot/dns-cloudflare@sha256:742dbd2e61c8709b930712c38958386c3cb3928e09eeb1f1e490600c127e2edb\\n    restart: unless-stopped\\n    entrypoint: \\\"/bin/sh -c 'trap exit TERM; while :; do certbot renew; sleep 12h & wait $${!}; done;'\\\"\\n    volumes:\\n      - certs:/etc/letsencrypt\\n    configs:\\n      - source: cloudflare_credentials\\n        target: /etc/cloudflare/credentials.ini\\n        mode: 0600\\n    depends_on:\\n      certbot-init:\\n        condition: service_completed_successfully\\n\\n  certbot-init:\\n    image: certbot/dns-cloudflare@sha256:742dbd2e61c8709b930712c38958386c3cb3928e09eeb1f1e490600c127e2edb\\n    volumes:\\n      - certs:/etc/letsencrypt\\n    restart: on-failure\\n    configs:\\n      - source: cloudflare_credentials\\n        target: /etc/cloudflare/credentials.ini\\n        mode: 0600\\n    command: >\\n      certonly\\n      --dns-cloudflare\\n      --dns-cloudflare-credentials /etc/cloudflare/credentials.ini\\n      --dns-cloudflare-propagation-seconds 30\\n      --email ${CERTBOT_EMAIL}\\n      --agree-tos --no-eff-email --non-interactive\\n      --key-type ecdsa --elliptic-curve secp256r1\\n      --cert-name completions.near.ai\\n      -d \\\"*.completions.near.ai\\\"\\n      -d \\\"completions.near.ai\\\"\\n      -d \\\"$HOSTNAME.hosts.near.ai\\\"\\n\\n  compose-manager:\\n    image: nearaidev/compose-manager@sha256:a3c6e223ae5643689e6f0ae78461c2cb2d1b52d5b4ea306dc354b9ac7096d6e2\\n    container_name: compose-manager\\n    restart: unless-stopped\\n    ports:\\n      - \\\"8080:8080\\\"\\n    volumes:\\n      - /var/run/docker.sock:/var/run/docker.sock\\n      - /var/run/dstack.sock:/var/run/dstack.sock\\n      - /dstack/.host-shared/.decrypted-env:/app/.env:ro\\n      - work:/app/work\\n    environment:\\n      - GITHUB_REPO=https://github.com/nearai/cvm-compose-files\\n      - BEARER_TOKEN=${BEARER_TOKEN}\\n      - WORK_DIR=/app/work\\n      - MIN_TAG_AGE_HOURS=2\\n      - ENV_FILES=/app/.env\\n    labels:\\n      com.datadoghq.ad.logs: '[{\\\"source\\\": \\\"compose-manager\\\", \\\"service\\\": \\\"compose-manager\\\"}]'\\n\\nvolumes:\\n  work:\\n  # This volume can be re-used by other containers that need access to the TLS certificates.\\n  certs:\\n    name: certs\\n\\nconfigs:\\n  cloudflare_credentials:\\n    content: |\\n      dns_cloudflare_api_token = ${CLOUDFLARE_API_TOKEN}\\n\\n  # Journald conf file content\\n  journald_config_file:\\n    content: |\\n      logs:\\n        - type: journald\\n          container_mode: true\\n          # TODO: Add filters to reduce log volume\\n\",\n    \"kms_enabled\": true,\n    \"gateway_enabled\": true,\n    \"local_key_provider_enabled\": false,\n    \"key_provider_id\": \"\",\n    \"public_logs\": false,\n    \"public_sysinfo\": true,\n    \"allowed_envs\": [\n        \"BEARER_TOKEN\",\n        \"AWS_REGION\",\n        \"AWS_ACCESS_KEY_ID\",\n        \"AWS_SECRET_ACCESS_KEY\",\n        \"AWS_S3_BUCKET\",\n        \"CERTBOT_EMAIL\",\n        \"CLOUDFLARE_API_TOKEN\",\n        \"DD_API_KEY\",\n        \"HUGGING_FACE_HUB_TOKEN\",\n        \"PROXY_TOKEN\",\n        \"ENV\",\n        \"HOST_IP\",\n        \"DD_HOSTNAME\",\n        \"HOSTNAME\"\n    ],\n    \"no_instance_id\": false,\n    \"secure_time\": false,\n    \"pre_launch_script\": \"#!/bin/bash\\nexport ENCRYPTION_KEY=$(cat /dstack/.host-shared/.appkeys.json | jq -r .k256_key)\\n\"\n}","compose_hash":"242a62724303cc32f364da0fc92738706b0078e7587821b7ba3e75488223797b","device_id":"71b4c123bc28aa4dd49845bb2785848b1fcb4f1b87b688472e690f1e5687f2d3","event_log":[{"digest":"60a36090e82db2aa82a7abb76029b9ace69e9f0811b7029ff25a26a2e8b91c182696df92674ab571c42093383e1fcc71","event":"","event_payload":"0954647854