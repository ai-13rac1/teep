3820c8053cee3ce29b5fb0fbcbc\"}","mr_aggregated":"bc95175343599e04c60a5f450c020d8d93958035838592dee89abea254a20174","os_image_hash":"9b69bb1698bacbb6985409a2c272bcb892e09cdcea63d5399c6768b67d3ff677","tcb_info":{"app_compose":"{\n    \"manifest_version\": 2,\n    \"name\": \"dstack-nvidia-0.5.5\",\n    \"runner\": \"docker-compose\",\n    \"docker_compose_file\": \"services:\\n  # Datadog Service Definition\\n  datadog-agent:\\n    image: datadog/agent@sha256:5556fb80b952832719a76b016f905616c76ee0989a239c4680c6220148e865d6\\n    container_name: datadog-agent\\n    environment:\\n      - DD_API_KEY=${DD_API_KEY}\\n      - DD_SITE=us3.datadoghq.com\\n      - DD_ENV=prod\\n      - DD_LOGS_ENABLED=true\\n      - DD_OTLP_CONFIG_LOGS_ENABLED=true\\n      - DD_LOGS_CONFIG_CONTAINER_COLLECT_ALL=true\\n      - DD_CONTAINER_EXCLUDE_LOGS=name:datadog-agent\\n      - DD_PROCESS_AGENT_ENABLED=true\\n      - DD_DOGSTATSD_NON_LOCAL_TRAFFIC=true\\n      - DD_HOSTNAME=$DD_HOSTNAME\\n      # Datadog Agent 7.61+ can fail to start its OTLP receiver in Docker\\n      # when it tries to collect process metrics through /host/proc.\\n      - HOST_PROC=/proc\\n      - DD_OTLP_CONFIG_RECEIVER_PROTOCOLS_GRPC_ENDPOINT=0.0.0.0:4317\\n    volumes:\\n      - /var/run/docker.sock:/var/run/docker.sock:ro\\n      - /proc/:/host/proc/:ro\\n      - /sys/fs/cgroup/:/host/sys/fs/cgroup:ro\\n      - /var/lib/docker/containers:/var/lib/docker/containers:ro\\n      - /run/log/journal:/run/log/journal:ro\\n      - /run/systemd/:/host/run/systemd/:ro\\n    configs:\\n      - source: journald_config_file\\n        target: /etc/datadog-agent/conf.d/journald.d/conf.yaml\\n        mode: 0755\\n    restart: unless-stopped\\n    logging:\\n      driver: \\\"local\\\"\\n      options:\\n        max-size: \\\"20m\\\"\\n        max-file: \\\"3\\\"\\n\\n  # OpenTelemetry collector sidecar for stable management visibility only.\\n  otelcol-management:\\n    image: otel/opentelemetry-collector-contrib@sha256:85ac41c2db88d0df9bd6145e608a3cb023f5d8443868adbfbbf66efb51087917\\n    container_name: otelcol-management\\n    command: [\\\"--config=/etc/otelcol-management/config.yaml\\\"]\\n    user: \\\"0:0\\\"\\n    mem_limit: \\\"768m\\\"\\n    environment:\\n      - MONITORING_INGEST_TOKEN=${MONITORING_INGEST_TOKEN}\\n      - CVM_NAME=${CVM_NAME}\\n      - CVM_HOST=${CVM_HOST}\\n      - DD_HOSTNAME=${DD_HOSTNAME}\\n      - ENV=${ENV}\\n    volumes:\\n      - /var/lib/docker/containers:/var/lib/docker/containers:ro\\n      - otelcol-management-storage:/var/lib/otelcol-management\\n    configs:\\n      - source: otelcol_management_config\\n        target: /etc/otelcol-management/config.yaml\\n        mode: 0444\\n    restart: unless-stopped\\n    # Avoid the collector tailing its own Docker JSON log and creating a\\n    # feedback loop. The host-side Phase 1 collector still captures VM\\n    # serial/stderr if this sidecar itself needs debugging.\\n    logging:\\n      driver: \\\"local\\\"\\n      options:\\n        max-size: \\\"20m\\\"\\n        max-file: \\\"3\\\"\\n\\n\\n  certbot:\\n    image: certbot/dns-cloudflare@sha256:742dbd2e61c8709b930712c38958386c3cb3928e09eeb1f1e490600c127e2edb\\n    restart: unless-stopped\\n    entrypoint: \\\"/bin/sh -c 'trap exit TERM; while :; do certbot renew; sleep 12h & wait $${!}; done;'\\\"\\n    volumes:\\n      - certs:/etc/letsencrypt\\n    configs:\\n      - source: cloudflare_credentials\\n        target: /etc/cloudflare/credentials.ini\\n        mode: 0600\\n    depends_on:\\n      certbot-init:\\n        condition: service_completed_successfully\\n    labels:\\n      com.datadoghq.ad.logs: '[{\\\"source\\\": \\\"dns-cloudflare\\\", \\\"service\\\": \\\"dns-cloudflare\\\"}]'\\n    logging:\\n      driver: \\\"json-file\\\"\\n      options:\\n        max-size: \\\"100m\\\"\\n        max-file: \\\"10\\\"\\n        labels: \\\"com.datadoghq.ad.logs,com.docker.compose.service\\\"\\n\\n\\n  certbot-init:\\n    image: certbot/dns-cloudflare@sha256:742dbd2e61c8709b930712c38958386c3cb3928e09eeb1f1e490600c127e2edb\\n    volumes:\\n      - certs:/etc/letsencrypt\\n    restart: on-failure\\n    configs:\\n      - source: cloudflare_credentials\\n        target: /etc/cloudflare/credentials.ini\\n        mode: 0600\\n    command: >\\n      certonly\\n      --dns-cloudflare\\n      --dns-cloudflare-credentials /etc/cloudflare/credentials.ini\\n      --dns-cloudflare-propagation-seconds 30\\n      --email ${CERTBOT_EMAIL}\\n      --agree-tos --no-eff-email --non-interactive\\n      --key-type ecdsa --elliptic-curve secp256r1\\n      --cert-name completions.near.ai\\n      -d \\\"*.completions.near.ai\\\"\\n      -d \\\"completions.near.ai\\\"\\n      -d \\\"$HOSTNAME.hosts.near.ai\\\"\\n    labels:\\n      com.datadoghq.ad.logs: '[{\\\"source\\\": \\\"dns-cloudflare\\\", \\\"service\\\": \\\"dns-cloudflare\\\"}]'\\n    logging:\\n      driver: \\\"json-file\\\"\\n      options:\\n        max-size: \\\"100m\\\"\\n        max-file: \\\"10\\\"\\n        labels: \\\"com.datadoghq.ad.logs,com.docker.compose.service\\\"\\n\\n\\n  compose-manager:\\n    image: ${COMPOSE_MANAGER_IMAGE:-nearaidev/compose-manager@sha256:b487f39160e9a53c3d98943a9c709d28e12babef75e0bb5a6cd5692abc8b2db6}\\n    container_name: compose-manager\\n    restart: unless-stopped\\n    ports:\\n      - \\\"8080:8080\\\"\\n    # pid:host + CAP_SYS_ADMIN + CAP_SYS_PTRACE let compose-manager run\\n    # `nsenter -t 1 -m -u -i -n -p -- ...` into PID 1's namespaces.\\n    #   - SYS_PTRACE: needed to open /proc/1/ns/* (ptrace_may_access gates\\n    #     this — PID 1 has `dumpable=0` because it was launched with a full\\n    #     cap set, so even root in the same user-ns needs SYS_PTRACE).\\n    #   - SYS_ADMIN: needed for the setns() that follows the open.\\n    # Without BOTH, every nsenter call fails with \\\"cannot open /proc/1/ns/*:\\n    # Permission denied\\\" — affecting `/dstack-agent/:action` (pre-existing)\\n    # and `/admin/kernel/algif-blacklist` (PR #14 / CVE-2026-31431).\\n    #\\n    # NOTE on AppArmor: on a host with AppArmor enabled, docker-default also\\n    # blocks this regardless of caps; the workable combo there is\\n    # `cap_add: [SYS_ADMIN, SYS_PTRACE]` PLUS `security_opt:\\n    # apparmor=unconfined`. dstack-OS does NOT ship AppArmor (verified\\n    # 2026-05-19 — no apparmor binaries/profiles in the rootfs, no AppArmor\\n    # strings in bzImage), so we omit the `security_opt` line. If a future\\n    # dstack-OS image enables AppArmor, this template must add it.\\n    pid: host\\n    cap_add:\\n      - SYS_ADMIN\\n      - SYS_PTRACE\\n    volumes:\\n      - /var/run/docker.sock:/var/run/docker.sock\\n      - /var/run/dstack.sock:/var/run/dstack.sock\\n      - /dstack/.host-shared/.decrypted-env:/app/.env:ro\\n      - work:/app/work\\n    environment:\\n      - GITHUB_REPO=https://github.com/nearai/cvm-compose-files\\n      - BEARER_TOKEN=${BEARER_TOKEN}\\n      - WORK_DIR=/app/work\\n      - MIN_TAG_AGE_HOURS=${CM_MIN_TAG_AGE_HOURS:-0}\\n      - ENV_FILES=/app/.env\\n      # Slack ops notifications (nearai/infra#141). INSTANCE_LABEL identifies\\n      # this host in the message (\\\"Deployed on gpuXX\\\"); SLACK_WEBHOOK_URL is a\\n      # secret sourced from the CVM decrypted env (empty = notifications off).\\n      - INSTANCE_LABEL=gpu30\\n      - SLACK_WEBHOOK_URL=${SLACK_WEBHOOK_URL:-}\\n    labels:\\n      com.datadoghq.ad.logs: '[{\\\"source\\\": \\\"compose-manager\\\", \\\"service\\\": \\\"compose-manager\\\"}]'\\n    logging:\\n      driver: \\\"json-file\\\"\\n      options:\\n        max-size: \\\"100m\\\"\\n        max-file: \\\"10\\\"\\n        labels: \\\"com.datadoghq.ad.logs,com.docker.compose.service\\\"\\n\\n\\n  compose-manager-launcher:\\n    image: nearaidev/compose-manager-launcher@sha256:78afb82330137c2fd90a9c8c6e452f8f178c15d863f87c079a11c13e92216e00\\n    container_name: compose-manager-launcher\\n    restart: unless-stopped\\n    # Host network so the launcher's health check (LAUNCHER_HEALTH_URL below,\\n    # http://127.0.0.1:8080/version) can reach compose-manager, which publishes\\n    # 8080 on the guest host via `ports: 8080:8080`. On the default bridge,\\n    # 127.0.0.1 is the launcher's own loopback and the check can never pass —\\n    # every swap/rollback would be wrongly declared failed.\\n    network_mode: host\\n    volumes:\\n      - /var/run/docker.sock:/var/run/docker.sock\\n      # Mounted read-only so the launcher can pass it as --env-file to docker compose,\\n      # allowing BEARER_TOKEN and other secrets to be substituted in the bundled\\n      # compose file without the launcher holding them in its own environment.\\n      - /dstack/.host-shared/.decrypted-env:/dstack-env:ro\\n      - work:/app/work\\n    environment:\\n      - COMPOSE_MANAGER_IMAGE_REPO=nearaidev/compose-manager\\n      # Keep launcher-driven recreates aligned with the initially booted\\n      # compose-manager container; the launcher's bundled compose file also\\n      # consumes this value.\\n      - CM_MIN_TAG_AGE_HOURS=${CM_MIN_TAG_AGE_HOURS:-0}\\n      - LAUNCHER_CHANNEL=${LAUNCHER_CHANNEL:-latest}\\n      - LAUNCHER_COMPOSE_PROJECT=dstack\\n      - LAUNCHER_ENV_FILE=/app/work/.env.launcher\\n      - LAUNCHER_BASE_ENV_FILE=/dstack-env\\n      - LAUNCHER_HEALTH_URL=http://127.0.0.1:8080/version\\n      # compose-manager does TLS/cert + S3 + git work on startup, so a container\\n      # recreate can take >60s to answer /version. 60s caused a genuine swap (and\\n      # its rollback) to be declared failed mid-startup -> false 30-min backoff.\\n      - LAUNCHER_HEALTH_TIMEOUT=180\\n      - LAUNCHER_COSIGN_IDENTITY_REGEXP=https://github.com/nearai/compose-manager/.github/workflows/.*\\n      - DOCKER_REGISTRY_USER=${DOCKER_REGISTRY_USER:-}\\n      - DOCKER_REGISTRY_TOKEN=${DOCKER_REGISTRY_TOKEN:-}\\n      - LAUNCHER_STATE_FILE=/app/work/launcher-state.json\\n    depends_on:\\n      - compose-manager\\n    labels:\\n      com.datadoghq.ad.logs: '[{\\\"source\\\": \\\"compose-manager-launcher\\\", \\\"service\\\": \\\"compose-manager-launcher\\\"}]'\\n    logging:\\n      driver: \\\"json-file\\\"\\n      options:\\n        max-size: \\\"100m\\\"\\n        max-file: \\\"10\\\"\\n        labels: \\\"com.datadoghq.ad.logs,com.docker.compose.service\\\"\\n\\n\\nnetworks:\\n  # Model compose files attach to this shared network so app-side telemetry can\\n  # reach management services such as datadog-agent without restarting the\\n  # compose-manager CVM for model scrape/log/trace changes.\\n  default:\\n    name: dstack_default\\n\\nvolumes:\\n  otelcol-management-storage:\\n\\n  work:\\n  # This volume can be re-used by other containers that need access to the TLS certificates.\\n  certs:\\n    name: certs\\n\\nconfigs:\\n  cloudflare_credentials:\\n    content: |\\n      dns_cloudflare_api_token = ${CLOUDFLARE_API_TOKEN}\\n\\n  # Journald conf file content\\n  journald_config_file:\\n    content: |\\n      logs:\\n        - type: journald\\n          container_mode: true\\n          # TODO: Add filters to reduce log volume\\n\\n  # otelcol-management config for compose-manager/launcher telemetry only.\\n# Dollar signs are escaped as $$ so docker compose leaves OTel's\\n# ${env:...} references intact.\\n  otelcol_management_config:\\n    content: |\\n      receivers:\\n        filelog/docker_containers:\\n          include: [/var/lib/docker/containers/*/*-json.log]\\n          start_at: end\\n          storage: file_storage\\n          include_file_path: true\\n          operators:\\n            - type: json_parser\\n              parse_from: body\\n              parse_to: attributes\\n              timestamp:\\n                parse_from: attributes.time\\n                layout_type: gotime\\n                layout: '2006-01-02T15:04:05.999999999Z07:00'\\n              on_error: send_quiet\\n            - type: move\\n              from: attributes.log\\n              to: body\\n              if: 'attributes.log != nil'\\n            - type: move\\n              from: attributes.stream\\n              to: attributes[\\\"log.iostream\\\"]\\n              if: 'attributes.stream != nil'\\n            - type: remove\\n              field: attributes.time\\n              if: 'attributes.time != nil'\\n            - type: regex_parser\\n              parse_from: attributes[\\\"log.file.path\\\"]\\n              regex: '/var/lib/docker/containers/(?P<container_id>[a-f0-9]{12})[a-f0-9]*/'\\n              on_error: send_quiet\\n            - type: add\\n              field: attributes[\\\"service.name\\\"]\\n              value: cvm-docker\\n\\n        prometheus/self:\\n          config:\\n            scrape_configs:\\n              - job_name: otelcol-management\\n                scrape_interval: 30s\\n                static_configs:\\n                  - targets: ['localhost:8888']\\n\\n      processors:\\n        memory_limiter:\\n          check_interval: 1s\\n          limit_mib: 512\\n          spike_limit_mib: 128\\n\\n        resource:\\n          attributes:\\n            - key: host.name\\n              value: $${env:DD_HOSTNAME}\\n              action: upsert\\n            - key: cvm.name\\n              value: $${env:CVM_NAME}\\n              action: upsert\\n            - key: host.machine\\n              value: $${env:CVM_HOST}\\n              action: insert\\n            - key: deployment.environment\\n              value: $${env:ENV}\\n              action: upsert\\n            - key: service.namespace\\n              value: near-ai\\n              action: insert\\n\\n        transform/docker_metadata:\\n          error_mode: ignore\\n          log_statements:\\n            - context: log\\n              statements:\\n                - set(attributes[\\\"service.name\\\"], attributes[\\\"attrs\\\"][\\\"com.docker.compose.service\\\"]) where attributes[\\\"attrs\\\"] != nil and attributes[\\\"attrs\\\"][\\\"com.docker.compose.service\\\"] != nil\\n                - set(attributes[\\\"service.name\\\"], ParseJSON(attributes[\\\"attrs\\\"][\\\"com.datadoghq.ad.logs\\\"])[0][\\\"service\\\"]) where attributes[\\\"attrs\\\"] != nil and attributes[\\\"attrs\\\"][\\\"com.datadoghq.ad.logs\\\"] != nil\\n                - set(attributes[\\\"log.source\\\"], ParseJSON(attributes[\\\"attrs\\\"][\\\"com.datadoghq.ad.logs\\\"])[0][\\\"source\\\"]) where attributes[\\\"attrs\\\"] != nil and attributes[\\\"attrs\\\"][\\\"com.datadoghq.ad.logs\\\"] != nil\\n                - set(attributes[\\\"container.name\\\"], attributes[\\\"attrs\\\"][\\\"com.docker.compose.service\\\"]) where attributes[\\\"attrs\\\"] != nil and attributes[\\\"attrs\\\"][\\\"com.docker.compose.service\\\"] != nil\\n\\n        filter/management_logs:\\n          error_mode: ignore\\n          logs:\\n            log_record:\\n              - 'attributes[\\\"service.name\\\"] != \\\"compose-manager\\\" and attributes[\\\"service.name\\\"] != \\\"compose-manager-launcher\\\" and attributes[\\\"service.name\\\"] != \\\"dns-cloudflare\\\"'\\n\\n        groupbyattrs/docker_service:\\n          keys:\\n            - service.name\\n            - container.name\\n            - log.source\\n            - log.iostream\\n\\n        batch:\\n          send_batch_size: 1024\\n          send_batch_max_size: 2048\\n          timeout: 5s\\n\\n      exporters:\\n        otlphttp/gateway:\\n          endpoint: https://telemetry.infra.near.ai\\n          headers:\\n            Authorization: \\\"Bearer $${env:MONITORING_INGEST_TOKEN}\\\"\\n          sending_queue:\\n            queue_size: 128\\n            storage: file_storage\\n\\n      extensions:\\n        file_storage:\\n          directory: /var/lib/otelcol-management/storage\\n          create_directory: true\\n\\n      service:\\n        extensions: [file_storage]\\n        pipelines:\\n          logs/cvm:\\n            receivers: [filelog/docker_containers]\\n            processors: [memory_limiter, resource, transform/docker_metadata, filter/management_logs, groupbyattrs/docker_service, batch]\\n            exporters: [otlphttp/gateway]\\n          metrics/self:\\n            receivers: [prometheus/self]\\n            processors: [memory_limiter, resource, batch]\\n            exporters: [otlphttp/gateway]\\n        telemetry:\\n          metrics:\\n            address: localhost:8888\\n          logs:\\n            level: info\\n\",\n    \"kms_enabled\": true,\n    \"gateway_enabled\": true,\n    \"local_key_provider_enabled\": false,\n    \"key_provider_id\": \"\",\n    \"public_logs\": false,\n    \"public_sysinfo\": true,\n    \"allowed_envs\": [\n        \"BEARER_TOKEN\",\n        \"CM_MIN_TAG_AGE_HOURS\",\n        \"SLACK_WEBHOOK_URL\",\n        \"AWS_REGION\",\n        \"AWS_ACCESS_KEY_ID\",\n        \"AWS_SECRET_ACCESS_KEY\",\n        \"AWS_S3_BUCKET\",\n        \"CERTBOT_EMAIL\",\n        \"CLOUDFLARE_API_TOKEN\",\n        \"DOCKER_REGISTRY_USER\",\n        \"DOCKER_REGISTRY_TOKEN\",\n        \"LAUNCHER_CHANNEL\",\n        \"DD_API_KEY\",\n        \"HUGGING_FACE_HUB_TOKEN\",\n        \"PROXY_TOKEN\",\n        \"ENV\",\n        \"HOST_IP\",\n        \"DD_HOSTNAME\",\n        \"HOSTNAME\",\n        \"MONITORING_INGEST_TOKEN\",\n        \"CVM_NAME\",\n        \"CVM_HOST\"\n    ],\n    \"no_instance_id\": false,\n    \"secure_time\": false,\n    \"pre_launch_script\": \"#!/bin/bash\\nexport ENCRYPTION_KEY=$(cat /dstack/.host-shared/.appkeys.json | jq -r .k256_key)\\n\"\n}","compose_hash":"66007399f064f058af68771c552bcae150c9f88622305631b5141da1aa2f7b7e","device_id":"aa781567445c6a3c11d26b41bd395aef2eb3cb343d9bb0e48ce34649c3d19e85","event_log":[{"digest":"60a36090e82db2aa82a7abb76029b9ace69e9f0811b7029ff25a26a2e8b91c182696df92674ab571c42093383e1fcc71","event":"","event_payload":"095464785461626c65000100000000000000af96bb93f2b9b84e9462e0ba745642360090800000000000","event_type":2147483659,"imr":0},{"digest":"344bc51c980ba621aaa00da3ed7436f7d6e549197dfe699515dfa2c6583d95e6412af